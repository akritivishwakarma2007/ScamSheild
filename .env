# ScamShield Honeypot - Environment Variables
# Copy this file to .env and update the values

# Ollama Configuration
# URL where Ollama is running
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for LLM analysis
# Recommended: qwen2.5:14b (best reasoning)
# Alternatives: llama3.2:3b (faster), gemma2:9b
# OLLAMA_MODEL=qwen2.5:14b
OLLAMA_MODEL=gemma2:2b
# or: OLLAMA_MODEL=phi3:mini     ← even smaller/faster
# LLM Temperature (lower = more deterministic)
OLLAMA_TEMPERATURE=0.1

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true
